---
// Brand logo: inline-SVG mark + "Sonus Auris / audio dashcam" wordmark, linking
// home. `size` scales the mark; `light` switches text colors for dark backgrounds.
interface Props {
  size?: number;
  light?: boolean;
}
const { size = 34, light = false } = Astro.props;
const word = light ? "#fffdf8" : "#0c2a22";
const sub = light ? "rgba(255,253,248,0.75)" : "#355a4f";
---

<a href={`${import.meta.env.BASE_URL}/`} class="logo" aria-label="Sonus Auris home">
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    role="img"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="logo-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#34c585"></stop>
        <stop offset="1" stop-color="#136f4f"></stop>
      </linearGradient>
    </defs>
    <rect width="64" height="64" rx="16" fill="url(#logo-g)"></rect>
    <path
      d="M24 44c-5 0-9-4-9-12 0-9 7-16 16-16s16 6 16 15c0 7-5 10-9 10-3 0-4-2-4-4s2-3 2-6c0-3-2-5-5-5s-5 2-5 6c0 6 1 8 1 12z"
      fill="none"
      stroke="#fffdf8"
      stroke-width="3.4"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <circle cx="44" cy="20" r="5" fill="#fd7e14"></circle>
  </svg>
  <span class="logo-text">
    <strong style={`color:${word}`}>Sonus Auris</strong>
    <small style={`color:${sub}`}>audio dashcam</small>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .logo-text strong {
    font-weight: 800;
    font-size: 1.18rem;
    letter-spacing: -0.02em;
  }
  .logo-text small {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
</style>

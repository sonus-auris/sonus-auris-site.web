---
// Sticky top navigation bar: logo, in-page anchor links (Features/How/Privacy/
// Open source), a GitHub link, and the primary "Get the app" CTA.
import Logo from "./Logo.astro";
const GITHUB_URL = "https://github.com/sonus-auris/sonus-auris";
---

<header class="nav">
  <div class="container nav-inner">
    <Logo />
    <nav class="nav-links" aria-label="Primary">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="#privacy">Privacy</a>
      <a href="#open-source">Open source</a>
    </nav>
    <div class="nav-cta">
      <a class="gh" href={GITHUB_URL} rel="noopener noreferrer" aria-label="View source on GitHub">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.74-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.71 1.03 1.62 1.03 2.74 0 3.92-2.34 4.78-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
      <a class="btn btn-primary btn-sm" href="#download">Get the app</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(1.4) blur(10px);
    background: rgba(255, 253, 248, 0.82);
    border-bottom: 1px solid rgba(12, 59, 46, 0.07);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    height: 70px;
  }
  .nav-links {
    display: none;
    gap: 26px;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .nav-links a {
    color: var(--ink-soft);
  }
  .nav-links a:hover {
    color: var(--green-700);
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gh {
    display: none;
    align-items: center;
    gap: 7px;
    font-weight: 700;
    color: var(--green-900);
  }
  .gh:hover {
    color: var(--green-700);
  }
  .btn-sm {
    padding: 10px 18px;
    font-size: 0.92rem;
  }
  @media (min-width: 860px) {
    .nav-links,
    .gh {
      display: inline-flex;
    }
  }
</style>

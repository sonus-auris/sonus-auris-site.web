---
import StoreButtons from "./StoreButtons.astro";
---

<section class="hero">
  <!-- floating cartoon doodles -->
  <span class="doodle d1" aria-hidden="true">🎸</span>
  <span class="doodle d2" aria-hidden="true">🎉</span>
  <span class="doodle d3" aria-hidden="true">🚗</span>
  <span class="doodle d4" aria-hidden="true">🎹</span>
  <span class="doodle d5" aria-hidden="true">🥁</span>

  <div class="container hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">🎙️ Always-on audio, never in your way</span>
      <h1>
        A <span class="hl">dashcam</span> for your
        <span class="hl-2">ears</span>.
      </h1>
      <p class="lead">
        Sonus Auris quietly records the world around you and backs it up to the
        cloud — so that <strong>killer riff</strong> at 2&nbsp;a.m., that perfect
        take in the car, or the one conversation you wish you'd kept is never
        lost to the void again.
      </p>

      <StoreButtons align="start" />

      <ul class="trust">
        <li>🔒 End-to-end encrypted</li>
        <li>🪪 Privacy-first by design</li>
        <li>💚 Open-source app</li>
      </ul>
    </div>

    <div class="hero-art" aria-hidden="true">
      <!-- Phone with a looping waveform — the "audio dashcam" -->
      <svg viewBox="0 0 360 460" class="phone" role="img">
        <defs>
          <linearGradient id="screen" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#0c3b2e"></stop>
            <stop offset="1" stop-color="#136f4f"></stop>
          </linearGradient>
          <linearGradient id="ring" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#ff9f43"></stop>
            <stop offset="1" stop-color="#e8590c"></stop>
          </linearGradient>
        </defs>

        <!-- phone body -->
        <rect x="40" y="20" width="280" height="420" rx="46" fill="#0c2a22"></rect>
        <rect x="52" y="32" width="256" height="396" rx="36" fill="url(#screen)"></rect>

        <!-- notch -->
        <rect x="150" y="44" width="60" height="12" rx="6" fill="#0c2a22"></rect>

        <!-- "REC" pill -->
        <g>
          <rect x="80" y="78" width="92" height="30" rx="15" fill="rgba(253,126,20,0.18)"></rect>
          <circle cx="98" cy="93" r="6" fill="#fd7e14">
            <animate attributeName="opacity" values="1;0.25;1" dur="1.4s" repeatCount="indefinite"></animate>
          </circle>
          <text x="112" y="98" fill="#ff9f43" font-family="Baloo 2, sans-serif" font-weight="800" font-size="15">REC</text>
        </g>
        <text x="262" y="98" fill="rgba(255,255,255,0.55)" font-family="Baloo 2, sans-serif" font-size="13" text-anchor="end">24h buffer</text>

        <!-- big circular record ring -->
        <circle cx="180" cy="220" r="74" fill="none" stroke="rgba(255,255,255,0.10)" stroke-width="14"></circle>
        <circle cx="180" cy="220" r="74" fill="none" stroke="url(#ring)" stroke-width="14"
                stroke-linecap="round" stroke-dasharray="350 465" transform="rotate(-90 180 220)">
          <animateTransform attributeName="transform" type="rotate" from="-90 180 220" to="270 180 220" dur="6s" repeatCount="indefinite"></animateTransform>
        </circle>
        <circle cx="180" cy="220" r="40" fill="#fd7e14"></circle>
        <rect x="170" y="210" width="20" height="20" rx="5" fill="#fffdf8"></rect>

        <!-- animated waveform bars -->
        <g fill="#34c585">
          <rect x="86" y="330" width="9" height="40" rx="4"><animate attributeName="height" values="40;14;40" dur="1.1s" repeatCount="indefinite"></animate><animate attributeName="y" values="330;343;330" dur="1.1s" repeatCount="indefinite"></animate></rect>
          <rect x="104" y="318" width="9" height="64" rx="4"><animate attributeName="height" values="64;26;64" dur="0.9s" repeatCount="indefinite"></animate><animate attributeName="y" values="318;337;318" dur="0.9s" repeatCount="indefinite"></animate></rect>
          <rect x="122" y="300" width="9" height="100" rx="4"><animate attributeName="height" values="100;40;100" dur="1.3s" repeatCount="indefinite"></animate><animate attributeName="y" values="300;330;300" dur="1.3s" repeatCount="indefinite"></animate></rect>
          <rect x="140" y="322" width="9" height="56" rx="4"><animate attributeName="height" values="56;20;56" dur="1s" repeatCount="indefinite"></animate><animate attributeName="y" values="322;340;322" dur="1s" repeatCount="indefinite"></animate></rect>
          <rect x="158" y="308" width="9" height="84" rx="4" fill="#ff9f43"><animate attributeName="height" values="84;30;84" dur="1.2s" repeatCount="indefinite"></animate><animate attributeName="y" values="308;335;308" dur="1.2s" repeatCount="indefinite"></animate></rect>
          <rect x="176" y="296" width="9" height="108" rx="4" fill="#ff9f43"><animate attributeName="height" values="108;44;108" dur="0.85s" repeatCount="indefinite"></animate><animate attributeName="y" values="296;328;296" dur="0.85s" repeatCount="indefinite"></animate></rect>
          <rect x="194" y="314" width="9" height="72" rx="4"><animate attributeName="height" values="72;28;72" dur="1.15s" repeatCount="indefinite"></animate><animate attributeName="y" values="314;336;314" dur="1.15s" repeatCount="indefinite"></animate></rect>
          <rect x="212" y="302" width="9" height="96" rx="4"><animate attributeName="height" values="96;36;96" dur="0.95s" repeatCount="indefinite"></animate><animate attributeName="y" values="302;332;302" dur="0.95s" repeatCount="indefinite"></animate></rect>
          <rect x="230" y="320" width="9" height="60" rx="4"><animate attributeName="height" values="60;22;60" dur="1.25s" repeatCount="indefinite"></animate><animate attributeName="y" values="320;339;320" dur="1.25s" repeatCount="indefinite"></animate></rect>
          <rect x="248" y="330" width="9" height="40" rx="4"><animate attributeName="height" values="40;14;40" dur="1.05s" repeatCount="indefinite"></animate><animate attributeName="y" values="330;343;330" dur="1.05s" repeatCount="indefinite"></animate></rect>
          <rect x="266" y="324" width="9" height="52" rx="4"><animate attributeName="height" values="52;18;52" dur="0.9s" repeatCount="indefinite"></animate><animate attributeName="y" values="324;341;324" dur="0.9s" repeatCount="indefinite"></animate></rect>
        </g>

        <!-- cloud backup badge -->
        <g>
          <rect x="96" y="396" width="168" height="14" rx="7" fill="rgba(255,255,255,0.10)"></rect>
          <rect x="96" y="396" width="120" height="14" rx="7" fill="#34c585"></rect>
        </g>
      </svg>

      <!-- little floating cloud showing the backup -->
      <svg viewBox="0 0 120 80" class="cloud" role="img">
        <path d="M30 60a18 18 0 0 1 2-36 24 24 0 0 1 46 6 16 16 0 0 1-4 30z" fill="#fff" stroke="#b7f0d2" stroke-width="3"></path>
        <path d="M52 30v18m0 0-7-7m7 7 7-7" fill="none" stroke="#1faa6c" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
          <animateTransform attributeName="transform" type="translate" values="0 0; 0 -4; 0 0" dur="1.8s" repeatCount="indefinite"></animateTransform>
        </path>
      </svg>
    </div>
  </div>

  <svg class="wave-divider" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 60 Q 180 0 360 40 T 720 40 T 1080 40 T 1440 30 V90 H0 Z" fill="#f4fbf6"></path>
  </svg>
</section>

<style>
  .hero {
    position: relative;
    background:
      radial-gradient(1100px 480px at 78% -8%, rgba(253, 126, 20, 0.14), transparent 60%),
      radial-gradient(900px 460px at 6% 0%, rgba(52, 197, 133, 0.18), transparent 55%),
      var(--paper);
    padding-top: clamp(36px, 6vw, 72px);
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    gap: 40px;
    align-items: center;
    padding-bottom: 70px;
  }
  .hero-copy h1 {
    font-size: clamp(2.6rem, 6.5vw, 4.6rem);
    margin-bottom: 0.25em;
  }
  .hl {
    color: var(--green-600, var(--green-700));
    background: linear-gradient(180deg, transparent 62%, var(--green-200) 62%);
    padding: 0 4px;
    border-radius: 4px;
  }
  .hl-2 {
    color: var(--orange-600);
  }
  .lead {
    font-size: 1.22rem;
    color: var(--ink-soft);
    max-width: 540px;
    margin-bottom: 28px;
  }
  .trust {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    padding: 0;
    margin: 26px 0 0;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--green-900);
  }
  .hero-art {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .phone {
    width: min(360px, 82vw);
    filter: drop-shadow(0 30px 50px rgba(12, 59, 46, 0.28));
    animation: float 6s ease-in-out infinite;
  }
  .cloud {
    position: absolute;
    top: -6px;
    right: 4%;
    width: 120px;
    animation: float 4.5s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  .doodle {
    position: absolute;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    opacity: 0.9;
    animation: bob 5s ease-in-out infinite;
    z-index: 1;
  }
  .d1 { top: 14%; left: 5%; animation-delay: 0s; }
  .d2 { top: 8%; right: 8%; animation-delay: 0.6s; }
  .d3 { bottom: 30%; left: 3%; animation-delay: 1.1s; }
  .d4 { top: 44%; right: 3%; animation-delay: 0.3s; }
  .d5 { bottom: 22%; right: 14%; animation-delay: 0.9s; }
  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-12px) rotate(4deg); }
  }
  @media (min-width: 940px) {
    .hero-inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
</style>

---
// A tongue-in-cheek "no spooks" band. The agency call-outs are a joke; the
// privacy-group membership badge is a satirical placeholder — swap it for a real
// affiliation (EFF member, etc.) before launch if you want it to be literal.
const guarantees = [
  { emoji: "🕵️", label: "CIA-free", sub: "no friends at Langley" },
  { emoji: "🛰️", label: "Mossad-free", sub: "shalom, but no" },
  { emoji: "🚪", label: "Zero backdoors", sub: "front door only, and it's locked" },
];
---

<section class="spooks" aria-label="Definitely no spies">
  <div class="container spooks-inner">
    <span class="eyebrow">🦅 Warrant canary, still chirping</span>
    <h2>Certified <span class="strike">spook</span> free.</h2>
    <p class="spooks-lead">
      No three-letter agency has a key, a tap, or a quiet little backdoor into
      Sonus Auris. We checked the closet. We checked under the bed. Nothing but
      AES-256 and good intentions.
    </p>

    <ul class="guarantees">
      {guarantees.map((g) => (
        <li class="guarantee">
          <span class="g-emoji">{g.emoji}</span>
          <strong>{g.label}</strong>
          <span class="g-sub">{g.sub}</span>
          <span class="g-stamp">✔ verified</span>
        </li>
      ))}
    </ul>

    <div class="member">
      <span class="member-badge" aria-hidden="true">🛡️</span>
      <p>
        Proud card-carrying member of the
        <strong>Consumers' Coalition for Cryptographic Liberty</strong> — the
        only club we'd ever let read our membership list.
      </p>
    </div>

    <p class="fine">
      🐤 If this canary ever stops chirping, assume someone made us stop. (As of
      today: chirping loudly, slightly smug.)
    </p>
  </div>
</section>

<style>
  .spooks {
    background:
      radial-gradient(700px 320px at 85% 10%, rgba(253, 126, 20, 0.12), transparent 60%),
      radial-gradient(700px 320px at 10% 90%, rgba(31, 170, 108, 0.14), transparent 60%),
      var(--paper-2);
    padding-block: clamp(54px, 8vw, 96px);
    text-align: center;
  }
  .spooks-inner {
    max-width: 760px;
  }
  .spooks h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-top: 12px;
  }
  .strike {
    position: relative;
    text-decoration: line-through;
    text-decoration-color: var(--orange-500);
    text-decoration-thickness: 4px;
    color: var(--ink-soft);
  }
  .spooks-lead {
    color: var(--ink-soft);
    font-size: 1.12rem;
    max-width: 560px;
    margin: 0 auto 30px;
  }
  .guarantees {
    list-style: none;
    padding: 0;
    margin: 0 0 30px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  .guarantee {
    background: #fff;
    border: 1px solid rgba(12, 59, 46, 0.08);
    border-radius: var(--radius);
    padding: 22px 18px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    transition: transform 0.15s ease;
  }
  .guarantee:hover {
    transform: translateY(-4px) rotate(-1deg);
  }
  .g-emoji {
    font-size: 2.2rem;
  }
  .guarantee strong {
    font-size: 1.2rem;
  }
  .g-sub {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
  .g-stamp {
    margin-top: 8px;
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-700);
    background: var(--green-50);
    border: 1px dashed var(--green-200);
    border-radius: 999px;
    padding: 4px 12px;
  }
  .member {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
    background: linear-gradient(135deg, var(--green-700), var(--green-900));
    color: #fffdf8;
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    box-shadow: var(--shadow-md);
  }
  .member-badge {
    font-size: 2.4rem;
    flex: none;
  }
  .member p {
    margin: 0;
    font-size: 1rem;
  }
  .member strong {
    color: #ffe0bd;
  }
  .fine {
    margin: 22px 0 0;
    font-size: 0.86rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  @media (min-width: 720px) {
    .guarantees {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

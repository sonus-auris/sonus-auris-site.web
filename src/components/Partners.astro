---
// These are neutral, self-describing capability badges — NOT third-party
// endorsements. Do not reintroduce real organisation/brand names here (it would
// imply an affiliation or endorsement Sonus Auris does not have). If you wire up
// genuine partners later, only use names you have written permission to display,
// and keep `icon` a hardcoded string literal (it is rendered via `set:html`, so
// it must never carry user- or CMS-supplied data without sanitisation).
const capabilities = [
  {
    name: "Sound matching",
    sub: "Find the moment fast",
    href: "#features",
    icon: `<circle cx="20" cy="20" r="13" fill="none" stroke="currentColor" stroke-width="2.4"/>
           <path d="M15 17c2-2 5-2 7 0M14 23c3-3 8-3 11 0M17 14.5c1.4-1 3.6-1 5 0" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>`,
  },
  {
    name: "Sleep & snore",
    sub: "Quiet-hours capture",
    href: "#features",
    icon: `<path d="M27 24a10 10 0 1 1-9-14 8 8 0 0 0 9 14z" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/>
           <path d="M22 12h5l-5 5h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    name: "Music capture",
    sub: "Studio-grade fidelity",
    href: "#features",
    icon: `<g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
             <path d="M12 8v24M20 8v24M28 8v24"/>
             <circle cx="12" cy="16" r="3" fill="#0a241c"/>
             <circle cx="20" cy="24" r="3" fill="#0a241c"/>
             <circle cx="28" cy="13" r="3" fill="#0a241c"/>
           </g>`,
  },
  {
    name: "Clear audio",
    sub: "Low-noise recording",
    href: "#features",
    icon: `<g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
             <path d="M11 16v8h4l6 5V11l-6 5z"/>
             <path d="M25 14a7 7 0 0 1 0 12M28 10a12 12 0 0 1 0 20"/>
           </g>`,
  },
];
---

<section class="partners" aria-label="What Sonus Auris is built for">
  <div class="container">
    <p class="partners-eyebrow">Built for every kind of capture</p>
    <ul class="partners-row">
      {capabilities.map((p) => (
        <li>
          <a class="partner" href={p.href}>
            <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true" set:html={p.icon}></svg>
            <span>
              <strong>{p.name}</strong>
              <small>{p.sub}</small>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners {
    border-bottom: 1px solid rgba(255, 253, 248, 0.1);
    padding: 34px 0 30px;
  }
  .partners-eyebrow {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
    font-weight: 800;
    color: rgba(255, 253, 248, 0.5);
    margin: 0 0 22px;
  }
  .partners-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px 34px;
  }
  .partner {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    color: rgba(255, 253, 248, 0.62);
    transition: color 0.16s ease, transform 0.16s ease;
  }
  .partner:hover {
    color: #fffdf8;
    transform: translateY(-2px);
  }
  .partner svg {
    flex: none;
  }
  .partner span {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    text-align: left;
  }
  .partner strong {
    font-weight: 800;
    font-size: 0.98rem;
    color: inherit;
  }
  .partner small {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 253, 248, 0.42);
  }
</style>

---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sonus Auris — A Dashcam for Audio",
  description = "Sonus Auris is the always-on audio dashcam. Never lose that killer riff again, and keep a private, secure record when you need one. Open-source app, privacy-first.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.svg" />
    <meta name="theme-color" content="#1faa6c" />

    <!-- Fun rounded brand font — self-hosted (see @font-face in global.css),
         so no third-party request and a tighter CSP. -->
    <link
      rel="preload"
      href="/fonts/baloo2.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
  </body>
</html>

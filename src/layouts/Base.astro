---
// Base HTML document layout. Renders <head> (title, description, favicon,
// Open Graph tags, self-hosted font preload) and a <body><slot/> for page
// content. Public asset URLs are prefixed with the GitHub Pages base path.
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sonus Auris — A Dashcam for Audio",
  description = "Sonus Auris is the always-on audio dashcam. Never lose that killer riff again, and keep a private, secure record when you need one. Open-source app, privacy-first.",
} = Astro.props;

// Public assets must be prefixed with the deploy base path so links work on
// the GitHub Pages subpath. BASE_URL has no trailing slash, so add one.
const base = import.meta.env.BASE_URL;
const ogImage = new URL(`${base}/og.svg`, Astro.site);
const fontFaceCss = `@font-face {
  font-family: "Baloo 2";
  font-style: normal;
  font-weight: 500 800;
  font-display: swap;
  src: url("${base}/fonts/baloo2.woff2") format("woff2");
}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="theme-color" content="#1faa6c" />

    <!-- Fun rounded brand font — self-hosted under the configured base path,
         so no third-party request and a tighter CSP. -->
    <link
      rel="preload"
      href={`${base}/fonts/baloo2.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:inline set:html={fontFaceCss}></style>
  </head>
  <body>
    <slot />
  </body>
</html>

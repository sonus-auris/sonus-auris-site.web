# Security headers for the static Sonus Auris site.
#
# WARNING: the current deploy target is GitHub Pages (see astro.config.mjs +
# .github/workflows/deploy.yml), and GitHub Pages does NOT honor `_headers` —
# this file is published as an inert text file at /_headers and NONE of the
# headers below are actually served. To enforce them, move hosting to a host
# that reads `_headers` (Netlify / Cloudflare Pages) or put the equivalent
# response headers in front of the origin (Cloudflare rules, CDN, nginx).
# A `<meta http-equiv>` CSP can approximate script/style/frame-src in the
# markup, but X-Frame-Options / frame-ancestors / HSTS require a real response
# header and cannot be set from static HTML on GitHub Pages.
#
# The site ships no client JavaScript and no forms, so the policy below is
# intentionally tight and the practical XSS/clickjacking surface is small.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: accelerometer=(), browsing-topics=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
